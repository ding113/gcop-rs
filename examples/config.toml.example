# gcop-rs Configuration File
# Location: ~/.config/gcop/config.toml (Linux) | ~/Library/Application Support/gcop/config.toml (macOS) | %APPDATA%\gcop\config\config.toml (Windows)
# Permissions: chmod 600 recommended (contains API keys, DO NOT commit to git)
#
# Full documentation: https://gcop.docs.esap.cc/guide/configuration.html

# --- LLM ---
[llm]
# Options: "claude" | "openai" | "ollama" | "gemini"
default_provider = "claude"

# Claude
[llm.providers.claude]
api_key = "sk-ant-api03-your-key-here"
model = "claude-sonnet-4-5-20250929"

# OpenAI
# [llm.providers.openai]
# api_style = "openai"  # optional for this built-in provider; inferred from the name
# api_key = "sk-your-openai-key-here"
# model = "gpt-4o-mini"
# strip_thinking = true      # optional: remove <thinking>...</thinking> / <think>...</think> blocks
#
# OpenAI Responses API
# [llm.providers.openai-response]
# api_style = "openai-response"
# api_key = "sk-your-openai-key-here"
# endpoint = "https://api.openai.com"
# model = "gpt-4o-mini"

# Ollama (local, requires `ollama serve` running)
# [llm.providers.ollama]
# endpoint = "http://localhost:11434"   # or a full /api/generate path
# model = "llama3.2"

# Gemini
# [llm.providers.gemini]
# api_key = "AIza-your-gemini-key"
# model = "gemini-3-flash-preview"

# --- Commit ---
[commit]
show_diff_preview = true
allow_edit = true
# split = true  # Always use atomic split commit mode

# --- UI ---
[ui]
colored = true
streaming = true
# language = "en"

# For advanced options (custom providers, fallback, network, review, etc.):
# https://gcop.docs.esap.cc/guide/configuration.html
