# gcop-rs 配置文件
# 位置: ~/.config/gcop/config.toml (Linux) | ~/Library/Application Support/gcop/config.toml (macOS) | %APPDATA%\gcop\config\config.toml (Windows)
# 权限建议: chmod 600 (包含 API 密钥，请勿提交到 git)
#
# 完整配置文档: https://gcop.docs.esap.cc/zh/guide/configuration.html

# --- LLM 配置 ---
[llm]
# 可选: "claude" | "openai" | "ollama" | "gemini"
default_provider = "claude"

# Claude
[llm.providers.claude]
api_key = "sk-ant-api03-your-key-here"
model = "claude-sonnet-4-5-20250929"

# OpenAI
# [llm.providers.openai]
# api_style = "openai"  # 内置 provider 可省略；会从名称推断
# api_key = "sk-your-openai-key-here"
# model = "gpt-4o-mini"
# strip_thinking = true      # 可选：移除 <thinking>...</thinking> / <think>...</think> 块
#
# OpenAI Responses API
# [llm.providers.openai-response]
# api_style = "openai-response"
# api_key = "sk-your-openai-key-here"
# endpoint = "https://api.openai.com"
# model = "gpt-4o-mini"

# Ollama（本地部署，需先运行 ollama serve）
# [llm.providers.ollama]
# endpoint = "http://localhost:11434"   # 或完整的 /api/generate 路径
# model = "llama3.2"

# Gemini
# [llm.providers.gemini]
# api_key = "AIza-your-gemini-key"
# model = "gemini-3-flash-preview"

# --- Commit 配置 ---
[commit]
show_diff_preview = true
allow_edit = true
# split = true  # 始终使用原子拆分提交模式

# --- UI 配置 ---
[ui]
colored = true
streaming = true
# language = "zh-CN"

# 更多配置项（自定义 provider、fallback、网络、review 等）请参考:
# https://gcop.docs.esap.cc/zh/guide/configuration.html
