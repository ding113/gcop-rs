# gcop 项目级配置
# 此文件应提交到版本控制，团队共享
# 文档：https://github.com/AptS-1547/gcop-rs
#
# 优先级：环境变量 (GCOP__*) > 项目配置 (.gcop/config.toml) > 用户配置 (~/.config/gcop/config.toml) > 默认值
# 警告：不要在此文件中填写 api_key —— 请使用环境变量或用户级配置

# --- LLM ---
# [llm]
# default_provider = "openai"

# [llm.providers.openai]
# model = "gpt-4o"
# ⚠ 不要在此文件中填写 api_key，请使用环境变量或用户级配置

# --- Commit ---
# [commit]
# custom_prompt = ""
# show_diff_preview = true
# split = true

# [commit.convention]
# style = "conventional"
# types = ["feat", "fix", "docs", "style", "refactor", "perf", "test", "chore", "ci"]
# template = "{type}({scope}): {subject}"
# extra_prompt = "所有 commit message 使用英文"

# --- Review ---
# [review]
# custom_prompt = ""
# min_severity = "warning"

# --- 文件配置 ---
# [file]
# 额外 lockfile glob pattern；匹配文件的完整 diff 永远不会发送给 LLM。
# 常见依赖 lockfile 已内置，会只保留摘要。
# lockfile_patterns = ["**/*.lock"]

# --- Workspace (monorepo) ---
# [workspace]
# enabled = true
# members = ["packages/*", "apps/*"]       # 覆盖自动检测
# scope_mappings = { "packages/core" = "core", "packages/ui" = "ui" }
